{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noUncheckedSideEffectImports": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2023",
    "tsBuildInfoFile": "./build/tsconfig.node.tsbuildinfo",
    "verbatimModuleSyntax": true,
    "types": ["electron-vite/node"]
  },
  "include": [
    "buildtools/vite/*.ts",
    "src/*.test.ts",
    "src/backend",
    "src/cli",
    "src/domain",
    "src/electron-env.d.ts",
    "src/gui",
    "src/index.ts",
    "src/native",
    "src/shared",
    "src/test"
  ]
}
