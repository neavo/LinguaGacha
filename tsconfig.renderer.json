{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "erasableSyntaxOnly": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "paths": {
      "@/*": ["./src/renderer/*"],
      "@base/*": ["./src/base/*"],
      "@gui/bridge-api": ["./src/gui/bridge/bridge-api.ts"],
      "@gui/bridge-types": ["./src/gui/bridge/bridge-types.ts"],
      "@core/api/core-api-endpoint": ["./src/core/api/core-api-endpoint.ts"],
      "@gui/external-url-policy": ["./src/gui/shell/external-url-policy.ts"],
      "@gui/ipc-contract": ["./src/gui/ipc/ipc-contract.ts"],
      "@gui/shell-contract": ["./src/gui/shell/shell-contract.ts"],
      "@shared/*": ["./src/shared/*"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2023",
    "tsBuildInfoFile": "./build/tsconfig.renderer.tsbuildinfo",
    "verbatimModuleSyntax": true
  },
  "include": [
    "src/renderer",
    "src/base",
    "src/shared",
    "src/gui/bridge/*.ts",
    "src/gui/ipc/*.ts",
    "src/gui/shell/shell-contract.ts",
    "src/gui/shell/external-url-policy.ts",
    "src/core/api/core-api-endpoint.ts",
    "src/electron-env.d.ts"
  ]
}
