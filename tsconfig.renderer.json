{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "erasableSyntaxOnly": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "paths": {
      "@/*": ["./src/renderer/*"],
      "@base/*": ["./src/base/*"],
      "@native/bridge-api": ["./src/native/bridge-api.ts"],
      "@native/bridge-types": ["./src/native/bridge-types.ts"],
      "@native/core-api-endpoint": ["./src/native/core-api-endpoint.ts"],
      "@native/external-url-policy": ["./src/native/external-url-policy.ts"],
      "@native/ipc-contract": ["./src/native/ipc-contract.ts"],
      "@native/shell-contract": ["./src/native/shell-contract.ts"],
      "@shared/*": ["./src/shared/*"],
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2023",
    "tsBuildInfoFile": "./build/tsconfig.renderer.tsbuildinfo",
    "verbatimModuleSyntax": true
  },
  "include": ["src/renderer", "src/base", "src/shared", "src/native/*.ts", "src/electron-env.d.ts"]
}
