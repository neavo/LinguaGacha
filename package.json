{
  "name": "linguagacha",
  "version": "0.0.0",
  "private": true,
  "description": "Next Generation AI translator for novels, games, subtitles, and more",
  "author": "neavo",
  "type": "module",
  "main": "build/dist-electron/index.js",
  "scripts": {
    "postinstall": "node ./node_modules/electron/install.js",
    "dev": "electron-vite dev --config buildtools/vite/electron.vite.config.ts",
    "build": "tsc -b --noEmit && electron-vite build --config buildtools/vite/electron.vite.config.ts && electron-builder --config buildtools/electron-builder/electron-builder.json5",
    "format": "node ./buildtools/format-related-files.mjs",
    "lint": "oxlint .",
    "test": "vitest run --config buildtools/vitest/vitest.config.ts",
    "check:frontend": "node ./buildtools/check-frontend-boundaries.mjs",
    "check:backend": "node ./buildtools/check-backend-boundaries.mjs",
    "check:boundaries": "npm run check:frontend && npm run check:backend"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.42.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^2.2.0",
    "@hono/node-server": "^2.0.2",
    "@lezer/highlight": "^1.2.3",
    "@tanstack/react-virtual": "^3.13.24",
    "ansis": "^4.3.0",
    "chardet": "^2.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "css-select": "^7.0.0",
    "dom-serializer": "^3.1.1",
    "domhandler": "^6.0.1",
    "domutils": "^4.0.2",
    "entities": "^8.0.0",
    "exceljs": "^4.4.0",
    "hono": "^4.12.18",
    "htmlparser2": "^12.0.0",
    "iconv-lite": "^0.7.2",
    "js-tiktoken": "^1.0.21",
    "jsonrepair": "^3.14.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "next-themes": "^0.4.6",
    "openai": "^6.37.0",
    "opencc-js": "^1.3.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "wrap-ansi": "^10.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "execa": "^9.6.1",
    "happy-dom": "^20.9.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  }
}
