// @see - https://www.electron.build/configuration/configuration
{
  $schema: "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  appId: "me.neavo.linguagacha",
  asar: true,
  productName: "LinguaGacha",
  // 复用 npm install 阶段已下载的 Electron，避免打包阶段再次下载同版本运行时
  electronDist: "node_modules/electron/dist",
  directories: {
    buildResources: "public",
    output: "build/release/${version}",
  },
  files: [
    "build/dist/**/*",
    "build/dist-electron/**/*",
  ],
  win: {
    target: [
      {
        target: "dir",
        arch: ["x64"],
      },
    ],
    executableName: "app",
    icon: "icon.png",
    extraFiles: [
      { from: "resource", to: "resource" },
      { from: "version.txt", to: "version.txt" },
    ],
  },
  mac: {
    target: [
      {
        target: "dmg",
        arch: ["x64", "arm64"],
      },
    ],
    artifactName: "${productName}_v${version}_macOS_${arch}.${ext}",
    category: "public.app-category.productivity",
    icon: "icon.png",
    identity: null,
    extraFiles: [
      { from: "resource", to: "MacOS/resource" },
      { from: "version.txt", to: "MacOS/version.txt" },
    ],
  },
  dmg: {
    sign: false,
  },
  linux: {
    target: [
      {
        target: "AppImage",
        arch: ["x64"],
      },
    ],
    artifactName: "${productName}_v${version}_Linux_${arch}.${ext}",
    category: "Utility",
    icon: "icon.png",
    extraFiles: [
      { from: "resource", to: "resource" },
      { from: "version.txt", to: "version.txt" },
    ],
  },
}
